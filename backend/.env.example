PORT=5000
MONGO_URI=mongodb://localhost:27017/study_abroad_crm
NODE_ENV=development

# JWT Secrets — use long random strings in production
JWT_ACCESS_SECRET=change_this_access_secret_min_32_chars
JWT_REFRESH_SECRET=change_this_refresh_secret_min_32_chars
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=7d

# CORS
CLIENT_ORIGIN=http://localhost:3000

# File Upload (Phase 1: local)
UPLOAD_DIR=uploads
MAX_FILE_SIZE_MB=10

# Email (optional — for notifications)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your@email.com
SMTP_PASS=your_app_password
EMAIL_FROM="Study Abroad CRM <noreply@studycrm.com>"
